{
  "include": ["src"],
  "compilerOptions": {
    "moduleResolution": "node",
    "baseUrl": ".",
    "alwaysStrict": true,
    "skipDefaultLibCheck": true,
    "skipLibCheck": true,
    "strict": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "incremental": true,
    "checkJs": true,
    "resolveJsonModule": true,
    "composite": true
  }
}
